      "textes": [
        {
          "niveau": "BODY",
          "texte": "Relation entre pharmacogénétique et la génétique de la schizophrénie",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Héritabilité de la schizophrénie est élevée (estimée entre 80% et 90%)",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Rôle des gènes impliqués complexe:",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Phénotype et génotype hétérogène",
          "indent": 1
        },
        {
          "niveau": "BODY",
          "texte": "Facteurs épigénétiques (régulation chimique de l’expression des gènes)",
          "indent": 1
        },
        {
          "niveau": "BODY",
          "texte": "Phénocopie (fausse schizophrénie) et pénétrance incomplète (prédisposé à la schizophrénie mais n’est pas apparue)",
          "indent": 1
        },
        {
          "niveau": "BODY",
          "texte": "Polygénique avec interaction(s) possible(s) = existence de plusieurs/nombreux facteurs génétiques",
