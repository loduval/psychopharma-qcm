      "has_content": true,
      "textes": [
        {
          "niveau": "BODY",
          "texte": "Qu’est-ce que la réponse au traitement en psychiatrie?Exemple de la schizophrénie",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "1/ Eradication des symptômes et retour des  « fonctions hautes » => guérison",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "2/ Réduction des symptômes ? rémission",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "3/ Amélioration de quelques traits ? réponse",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "6",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Réponse au traitement:",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Réduction de 50% d’un ou de plusieurs symptômes après 8 à 12 semaines de traitement",
          "indent": 0
        }
      ],
      "tableaux": [],
      "notes": ""
    },
    {
