      "textes": [
        {
          "niveau": "BODY",
          "texte": "La saga du gène DRD3 (I)",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Récepteur DRD3 (R dopamine) localisé dans l’aire mésolimbique",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "1ère association entre le variant ser9gly BalI du gène DRD3 et la schizophrénie (Crocq et al., 1992)",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "3 réplication consécutives (Nanko, 1994; Kennedy, 1995; Griffon, 1996)",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "25 autres études négatives",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Méta-analyse globale négative, mais présence d’un faible impact indirect",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "OR=1.09, 95%CI=0.98-1.22",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "OR=1.25, 95%CI=1.05-1.49 (Williams, 1998; Dubertret, 1998)",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "=>Le phénotype concerné n’est pas le trouble mais est inconnu…",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "10",
          "indent": 0
        }
      ],
      "tableaux": [],
      "notes": ""
    },
