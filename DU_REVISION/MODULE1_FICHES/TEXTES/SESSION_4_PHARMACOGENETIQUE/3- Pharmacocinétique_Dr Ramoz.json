    },
    {
      "num": 20,
      "has_content": true,
      "textes": [
        {
          "niveau": "BODY",
          "texte": "Impact des métaboliseurs du CYP2D6 sur la réponse au traitement",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "20",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Métaboliseurs rapides",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Risque d’inefficacité (apparente), sauf si métabolites actifs",
          "indent": 1
        },
        {
          "niveau": "H1",
          "texte": "Métaboliseurs lents",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Concentration plasmatique plus élevée",
          "indent": 1
        },
        {
          "niveau": "BODY",
          "texte": "Plus d’effets indésirables",
          "indent": 1
        },
        {
          "niveau": "H1",
          "texte": "Sédation (apaisement mais parfois perte de la conscience)",
          "indent": 2
        },
        {
          "niveau": "H1",
          "texte": "DT (délirium tremens: forte agitation, tremblements, troubles de la conscience)",
          "indent": 2
        },
        {
          "niveau": "H1",
          "texte": "etc…",
          "indent": 2
        }
      ],
      "tableaux": [],
      "notes": ""
    },
    {
      "num": 21,
