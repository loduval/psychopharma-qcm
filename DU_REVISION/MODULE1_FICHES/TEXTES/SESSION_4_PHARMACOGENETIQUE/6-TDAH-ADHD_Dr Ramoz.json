          "niveau": "BODY",
          "texte": "PHARMACOGÉNÉTIQUEGÈNES CANDIDATS : Voie Dopaminergique",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "DAT: disponibilité augmentée chez TDAH (1)",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Inhibition du DAT par le MéthylPhénidate (2)",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Lien génotype 10-R DAT et disponibilité (3)",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Études d’association DAT1/SLC6A3, DRD4",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "=> DAT, DRD4",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "12",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "(1): Dougherty DD et al Lancet. 1999",
          "indent": 0
        },
        {
          "niveau": "BODY",
