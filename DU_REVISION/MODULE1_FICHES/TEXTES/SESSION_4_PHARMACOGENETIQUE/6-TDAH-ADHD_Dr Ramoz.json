      "textes": [
        {
          "niveau": "BODY",
          "texte": "Des gènes de vulnérabilité au TDAH ?",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Triade: déficit d’attention, hyperactivité et impulsivité, neurodéveloppemental 4/1 garçons/fille",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Ql (sévérité, stabilité) ou trait, donc phénotype aux frontières non délimitées",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Formes différentes (attentionnelle vs motrice-impulsive)",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Facteur de risque pour addiction et psychopathie",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Voie DA :",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "Renforcement et DA (émotion/cognitions)",
          "indent": 1
        },
        {
          "niveau": "BODY",
          "texte": "Traitements = Amphétamines (bloque DAT et libère dopamine et noradrénaline)",
          "indent": 1
        },
        {
          "niveau": "H2",
          "texte": "Circuits de régulations dopaminergiques des aires préfrontales et ganglions de la base réduites de 10% chez les enfants hyperactifs (Castellanos, 1997 ; Swanson et al., 1998)",
          "indent": 1
        },
        {
          "niveau": "BODY",
          "texte": "6",
          "indent": 0
        }
      ],
