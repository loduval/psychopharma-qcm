          "texte": "13",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Facteur de rétrocontrôle négatif des récepteurs aux glucocorticoïdes (GR)",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "1/FKBP5 fixe GR, réduit l’affinité du cortisol",
          "indent": 0
