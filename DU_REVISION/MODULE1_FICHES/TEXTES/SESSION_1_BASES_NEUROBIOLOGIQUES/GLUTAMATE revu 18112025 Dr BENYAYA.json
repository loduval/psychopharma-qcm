        },
        {
          "niveau": "H2",
          "texte": "Kétamine: anesthésique général; traitement des dépressions résistantes dites « malignes »",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "(Cf.  Annexe diaporama glutamate Kétamine)",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "Faibles affinité:",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "Amantadine  Antiparkinsonien",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "Mémantine (diméthyl- Amantadine) : Antiparkinsonien; médicament du traitement de la maladie d’Alzheimer",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "Dextrométorphane Antitussif ;analgésique. analogue structural de la morphine; pas d’affinité pour les",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "récepteurs opioergiques",
          "indent": 0
        },
        {
          "niveau": "BODY",
