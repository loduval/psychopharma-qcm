          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "Premiers travaux    J.W Olney Science, 1969",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "“In newborn mice subcutaneous injections of monosodium glutamate induced acute neuronal necrosis in several regions of developing brain including the hypothalamus”",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "J.W Olney 1971",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "“Nécrose neuronale provoquée par  injection de Glutamate dans  l’ hypothalamus de souriceau",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Les lesions sont nettement limitées aux cellules post synaptiques: l s dendrites des neurones cibles étaient fortement gonflées tandis que les  terminaisons présynaptiques étaient épargnées”",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "J.W Olney , Nature, 1978",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "50 nmoles Glutamate dans le striatum de rat => dégénérescence neuronale; modèle",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "Neuropathologique de la maladie de Huntington",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "(solution saline, solution GABA: aucune lesion du parenchyme striatal)",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "27",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "Excitotoxicité",
          "indent": 0
        },
        {
