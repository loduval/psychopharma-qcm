      "textes": [
        {
          "niveau": "BODY",
          "texte": "Médicament de l’anesthésie générale",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "« Anesthésie dissociative »",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "Pharmacologie de la Kétamine",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "L’administration de  kétamine en anesthésie générale provoque un état de profonde analgésie sans dissolution obligatoire de la conscience",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Il y a une dissociation de l’activité électrique thalamo-corticale de celle qui est réticulaire et limbique:",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Dépression de la première et conservation de la seconde.",
          "indent": 0
        }
      ],
      "tableaux": [],
      "notes": ""
    },
    {
      "num": 17,
      "has_content": true,
      "textes": [
        {
          "niveau": "H2",
          "texte": "Pharmacologie de la S (+) Kétamine",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Filiation structurale de la Kétamine",
          "indent": 0
        },
