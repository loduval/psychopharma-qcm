      "textes": [
        {
          "niveau": "H1",
          "texte": "Anxiété d’état vs. Anxiété de trait",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Labyrinthe en Croix surélevé : Anxiété d’état",
          "indent": 0
        },
        {
          "niveau": "H2",
          "texte": "Anxiété liée à une situation ponctuelle dans laquelle se trouve le sujet. Ce processus anxieux est « normal »",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Anxiété de trait : Anxiété constitutive d’un sujet. Elle est",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "permanente et indépendante d’une situation particulière. Ce",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "processus anxieux est « pathologique »",
          "indent": 0
        },
        {
          "niveau": "H1",
          "texte": "Comment mesurer l’anxiété de trait chez les rongeurs ?",
          "indent": 0
        }
