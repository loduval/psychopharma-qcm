          "texte": "un acide α  aminé\t\t\t\t oui   non",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "plutôt neurotransmetteur \t\t\t oui   non",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "plutôt neuromodulateur\t\t\t oui   non",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "==============================================================================================Le récepteur GABA ionotrope:",
          "indent": 0
        },
        {
          "niveau": "BODY",
          "texte": "est doué de propriétés allostériques \t\toui non",
          "indent": 0
        },
        {
          "niveau": "BODY",
